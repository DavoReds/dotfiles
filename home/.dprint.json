{
  "lineWidth": 80,
  "indentWidth": 4,
  "newLineKind": "system",
  "useTabs": false,
  "typescript": {
    "indentWidth": 2,
    "semiColons": "always",
    "quoteStyle": "alwaysDouble",
    "quoteProps": "asNeeded",
    "useBraces": "always",
    "bracePosition": "sameLine",
    "trailingCommas": "onlyMultiLine",
    "arrowFunction.useParentheses": "force",
    "jsxExpressionContainer.spaceSurroundingExpression": true
  },
  "css": { "indentWidth": 2 },
  "prettier": {
    "associations": [
      "!**/*.js",
      "!**/*.ts",
      "!**/*.jsx",
      "!**/*.tsx",
      "!**/*.css",
      "!**/*.md"
    ],
    "indentWidth": 2,
    "proseWrap": "always",
    "plugin.jsDoc": true
  },
  "json": { "preferSingleLine": true, "indentWidth": 2 },
  "markdown": {
    "lineWidth": 120,
    "textWrap": "maintain",
    "emphasisKind": "asterisks",
    "strongKind": "asterisks"
  },
  "toml": { "indentWidth": 2, "lineWidth": 80 },
  "dockerfile": { "lineWidth": 80, "newLineKind": "system" },
  "ruff": { "lineLength": 80 },
  "sql": { "indentWidth": 2 },
  "excludes": ["**/node_modules", "**/*-lock.json"],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.91.0.wasm",
    "https://plugins.dprint.dev/json-0.19.3.wasm",
    "https://plugins.dprint.dev/markdown-0.17.1.wasm",
    "https://plugins.dprint.dev/toml-0.6.2.wasm",
    "https://plugins.dprint.dev/dockerfile-0.3.2.wasm",
    "https://plugins.dprint.dev/ruff-0.3.4.wasm",
    "https://plugins.dprint.dev/disrupted/css-0.2.3.wasm",
    "https://plugins.dprint.dev/sql-0.2.0.wasm",
    "https://plugins.dprint.dev/prettier-0.40.0.json@68c668863ec834d4be0f6f5ccaab415df75336a992aceb7eeeb14fdf096a9e9c"
  ]
}
